+    def _agent_sdk_bridge(self):
+        """Lazily build the shared AgentSDKBridge (Claude Code engine, subscription)."""
+        bridge = getattr(self, "_sdk_bridge", None)
+        if bridge is not None:
+            return bridge
+        import os
+        from pathlib import Path as _Path
+        from agent_sdk_bridge import AgentSDKBridge, BridgeConfig, FileSessionMap
+        try:
+            from hermes_constants import get_hermes_home
+            home = str(get_hermes_home())
+        except Exception:
+            home = os.path.expanduser("~/.hermes")
+        user_config = _load_gateway_config()
+        term = user_config.get("terminal") or {}
+        cwd = term.get("cwd") or os.path.expanduser("~")
+        tools_mode = (os.environ.get("HERMES_SDK_TOOLS") or "full").strip().lower()
+        cfg = BridgeConfig(
+            cwd=cwd,
+            permission_mode=os.environ.get("HERMES_SDK_PERMISSION_MODE", "bypassPermissions"),
+            tools=[] if tools_mode == "chat" else None,
+        )
+        smap = FileSessionMap(_Path(home) / "agent_sdk_sessions.json")
+        bridge = AgentSDKBridge(cfg, session_map=smap)
+        self._sdk_bridge = bridge
+        return bridge
+
+    async def _run_agent_via_sdk_bridge(
+        self,
+        message: str,
+        source: SessionSource,
+        session_key: Optional[str] = None,
+        run_generation: Optional[int] = None,
+    ) -> Dict[str, Any]:
+        """Run one turn via the Claude Agent SDK; return the _run_agent contract dict."""
+        bridge = self._agent_sdk_bridge()
+        key = session_key or f"{getattr(source.platform, 'value', source.platform)}:{source.chat_id}"
+        logger.info("[agent_sdk_bridge] turn via Claude Code engine (subscription), key=%s", key)
+        # Inject Hermes file-memory (MEMORY.md/USER.md) into this turn's system prompt.
+        extra_append = None
+        try:
+            from pathlib import Path as _MemPath
+            from agent_sdk_bridge import load_memory_append
+            from hermes_constants import get_hermes_home
+            _mem_cfg = _load_gateway_config().get("memory") or {}
+            extra_append = load_memory_append(
+                _MemPath(str(get_hermes_home())) / "memories",
+                memory_char_limit=int(_mem_cfg.get("memory_char_limit") or 2200),
+                user_char_limit=int(_mem_cfg.get("user_char_limit") or 1375),
+            )
+        except Exception:
+            logger.debug("[agent_sdk_bridge] memory load failed", exc_info=True)
+        try:
+            result = await bridge.run_turn(key, message, extra_system_append=extra_append)
+        except Exception as e:
+            logger.exception("agent_sdk_bridge turn failed (key=%s)", key)
+            return {
+                "final_response": f"⚠️ Agent SDK error: {e}",
+                "messages": [],
+                "api_calls": 0,
+                "completed": False,
+            }
+        return {
+            "final_response": result.text or "(empty)",
+            "messages": [],
+            "api_calls": result.num_turns or 1,
+            "completed": not result.is_error,
+        }
+
